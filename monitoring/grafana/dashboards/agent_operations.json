        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "100 * (sum(rate(langgraph_pipeline_success_total[5m])) / sum(rate(langgraph_pipeline_total[5m])))",
