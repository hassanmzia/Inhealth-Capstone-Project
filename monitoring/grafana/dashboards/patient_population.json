{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "piechart", "name": "Pie chart", "version": ""},
    {"type": "panel", "id": "bargauge", "name": "Bar gauge", "version": ""},
    {"type": "panel", "id": "table", "name": "Table", "version": ""}
  ],
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Total Active Patients",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum(inhealth_patients_active_total)",
          "legendFormat": "Active Patients"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {"color": "blue", "value": null},
              {"color": "green", "value": 100}
            ]
          },
          "unit": "short"
        }
      }
    },
    {
      "title": "High Risk Patients",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [
        {
          "expr": "sum(inhealth_patients_risk_level{level=\"high\"}) + sum(inhealth_patients_risk_level{level=\"critical\"})",
          "legendFormat": "High/Critical Risk"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "red"},
          "unit": "short"
        }
      }
    },
    {
      "title": "Average Population Risk Score",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "avg(inhealth_patient_risk_score)",
          "legendFormat": "Avg Risk Score"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.3},
              {"color": "orange", "value": 0.5},
              {"color": "red", "value": 0.7}
            ]
          },
          "unit": "percentunit",
          "decimals": 2
        }
      }
    },
    {
      "title": "Open Care Gaps",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [
        {
          "expr": "sum(inhealth_care_gaps_total{status=\"open\"})",
          "legendFormat": "Open Gaps"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "orange"},
          "unit": "short"
        }
      }
    },
    {
      "title": "Risk Stratification Distribution",
      "type": "piechart",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 4},
      "targets": [
        {"expr": "sum(inhealth_patients_risk_level{level=\"low\"})", "legendFormat": "Low Risk"},
        {"expr": "sum(inhealth_patients_risk_level{level=\"medium\"})", "legendFormat": "Medium Risk"},
        {"expr": "sum(inhealth_patients_risk_level{level=\"high\"})", "legendFormat": "High Risk"},
        {"expr": "sum(inhealth_patients_risk_level{level=\"critical\"})", "legendFormat": "Critical"}
      ],
      "fieldConfig": {
        "overrides": [
          {"matcher": {"id": "byName", "options": "Low Risk"}, "properties": [{"id": "color", "value": {"fixedColor": "green"}}]},
          {"matcher": {"id": "byName", "options": "Medium Risk"}, "properties": [{"id": "color", "value": {"fixedColor": "yellow"}}]},
          {"matcher": {"id": "byName", "options": "High Risk"}, "properties": [{"id": "color", "value": {"fixedColor": "orange"}}]},
          {"matcher": {"id": "byName", "options": "Critical"}, "properties": [{"id": "color", "value": {"fixedColor": "red"}}]}
        ]
      }
    },
    {
      "title": "Disease Prevalence by Condition",
      "type": "bargauge",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 4},
      "targets": [
        {"expr": "sum by (condition) (inhealth_patients_by_condition)", "legendFormat": "{{condition}}"}
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {"color": "blue", "value": null},
              {"color": "yellow", "value": 100},
              {"color": "red", "value": 500}
            ]
          }
        }
      },
      "options": {"orientation": "horizontal", "displayMode": "gradient"}
    },
    {
      "title": "Care Gap Rates by Category",
      "type": "bargauge",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 4},
      "targets": [
        {"expr": "sum by (gap_type) (inhealth_care_gaps_total{status=\"open\"})", "legendFormat": "{{gap_type}}"}
      ],
      "options": {"orientation": "horizontal", "displayMode": "gradient"}
    },
    {
      "title": "Risk Score Distribution Over Time",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [
        {"expr": "sum(inhealth_patients_risk_level{level=\"low\"})", "legendFormat": "Low"},
        {"expr": "sum(inhealth_patients_risk_level{level=\"medium\"})", "legendFormat": "Medium"},
        {"expr": "sum(inhealth_patients_risk_level{level=\"high\"})", "legendFormat": "High"},
        {"expr": "sum(inhealth_patients_risk_level{level=\"critical\"})", "legendFormat": "Critical"}
      ],
      "fieldConfig": {
        "defaults": {"custom": {"fillOpacity": 30, "stacking": {"mode": "normal"}}}
      }
    },
    {
      "title": "Predictive Model Confidence Trend",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [
        {"expr": "avg(inhealth_prediction_confidence{model=\"xgboost_7day_v2\"})", "legendFormat": "XGBoost 7-Day Risk"},
        {"expr": "avg(inhealth_prediction_confidence{model=\"rf_disease_v1\"})", "legendFormat": "RF Disease Classification"},
        {"expr": "avg(inhealth_prediction_confidence{model=\"lstm_glucose_v1\"})", "legendFormat": "LSTM Glucose Prediction"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "percentunit", "min": 0, "max": 1}
      }
    },
    {
      "title": "SDOH Risk Score Distribution",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum(rate(inhealth_sdoh_risk_score_bucket[1h])) by (le))", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.90, sum(rate(inhealth_sdoh_risk_score_bucket[1h])) by (le))", "legendFormat": "p90"},
        {"expr": "histogram_quantile(0.99, sum(rate(inhealth_sdoh_risk_score_bucket[1h])) by (le))", "legendFormat": "p99"}
      ]
    },
    {
      "title": "Disease Prevalence Trends by Tenant",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "targets": [
        {"expr": "sum by (tenant, condition) (inhealth_patients_by_condition)", "legendFormat": "{{tenant}} - {{condition}}"}
      ]
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["inhealth", "population-health", "analytics"],
  "templating": {"list": []},
  "time": {"from": "now-7d", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "InHealth - Population Health Analytics",
  "uid": "inhealth-population-health"
}
