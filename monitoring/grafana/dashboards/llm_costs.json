{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "bargauge", "name": "Bar gauge", "version": ""},
    {"type": "panel", "id": "table", "name": "Table", "version": ""},
    {"type": "panel", "id": "piechart", "name": "Pie chart", "version": ""}
  ],
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Total LLM Cost (Today)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum(increase(inhealth_llm_cost_usd_total[24h]))",
          "legendFormat": "Cost Today"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 10},
              {"color": "red", "value": 50}
            ]
          }
        }
      }
    },
    {
      "title": "Total Tokens (Today)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [
        {
          "expr": "sum(increase(inhealth_llm_tokens_total[24h]))",
          "legendFormat": "Tokens"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short", "decimals": 0}
      }
    },
    {
      "title": "LLM Calls (Today)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "sum(increase(inhealth_llm_calls_total[24h]))",
          "legendFormat": "Calls"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short", "decimals": 0}
      }
    },
    {
      "title": "Avg Latency (LLM)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [
        {
          "expr": "avg(rate(inhealth_llm_latency_seconds_sum[5m]) / rate(inhealth_llm_latency_seconds_count[5m]))",
          "legendFormat": "Avg Latency"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 2},
              {"color": "red", "value": 5}
            ]
          }
        }
      }
    },
    {
      "title": "Cost by Agent Type",
      "type": "piechart",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 4},
      "targets": [
        {
          "expr": "sum by (agent) (increase(inhealth_llm_cost_usd_total[24h]))",
          "legendFormat": "{{agent}}"
        }
      ]
    },
    {
      "title": "Token Usage by Model",
      "type": "bargauge",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 4},
      "targets": [
        {
          "expr": "sum by (model) (increase(inhealth_llm_tokens_total[24h]))",
          "legendFormat": "{{model}}"
        }
      ],
      "options": {"orientation": "horizontal", "displayMode": "gradient"}
    },
    {
      "title": "Cost by Model Provider",
      "type": "bargauge",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 4},
      "targets": [
        {
          "expr": "sum by (provider) (increase(inhealth_llm_cost_usd_total[24h]))",
          "legendFormat": "{{provider}}"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "currencyUSD"}
      },
      "options": {"orientation": "horizontal", "displayMode": "gradient"}
    },
    {
      "title": "LLM Cost Over Time (by Agent Tier)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [
        {"expr": "sum by (tier) (rate(inhealth_llm_cost_usd_total[1h]) * 3600)", "legendFormat": "Tier {{tier}}"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {"fillOpacity": 20, "stacking": {"mode": "normal"}}
        }
      }
    },
    {
      "title": "Token Usage Over Time (Input vs Output)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [
        {"expr": "sum(rate(inhealth_llm_tokens_total{type=\"input\"}[5m]))", "legendFormat": "Input Tokens/s"},
        {"expr": "sum(rate(inhealth_llm_tokens_total{type=\"output\"}[5m]))", "legendFormat": "Output Tokens/s"}
      ]
    },
    {
      "title": "LLM Response Latency Distribution",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum(rate(inhealth_llm_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, sum(rate(inhealth_llm_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p95"},
        {"expr": "histogram_quantile(0.99, sum(rate(inhealth_llm_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p99"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "s"}
      }
    },
    {
      "title": "LLM Call Success/Failure Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "targets": [
        {"expr": "sum(rate(inhealth_llm_calls_total{status=\"success\"}[5m]))", "legendFormat": "Success"},
        {"expr": "sum(rate(inhealth_llm_calls_total{status=\"error\"}[5m]))", "legendFormat": "Error"},
        {"expr": "sum(rate(inhealth_llm_calls_total{status=\"timeout\"}[5m]))", "legendFormat": "Timeout"}
      ],
      "fieldConfig": {
        "overrides": [
          {"matcher": {"id": "byName", "options": "Error"}, "properties": [{"id": "color", "value": {"fixedColor": "red"}}]},
          {"matcher": {"id": "byName", "options": "Timeout"}, "properties": [{"id": "color", "value": {"fixedColor": "orange"}}]}
        ]
      }
    },
    {
      "title": "Top 10 Most Expensive Agent Calls (24h)",
      "type": "table",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 28},
      "targets": [
        {
          "expr": "topk(10, sum by (agent, model) (increase(inhealth_llm_cost_usd_total[24h])))",
          "legendFormat": "{{agent}} ({{model}})",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "currencyUSD"}
      }
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["inhealth", "llm", "costs", "langfuse"],
  "templating": {"list": []},
  "time": {"from": "now-24h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "InHealth - LLM Cost & Quality Tracking",
  "uid": "inhealth-llm-costs"
}
